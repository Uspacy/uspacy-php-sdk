{
    "name": "uspacy/uspacy-php-sdk",
    "type": "library",
    "description": "PHP SDK for Uspacy – a single workspace for managing key processes of your organization with a focus on results.",
    "keywords": [
        "crm",
        "sdk",
        "uspacy",
        "api",
        "messenger"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Kyrylo Melnychuk",
            "email": "km@uspacy.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.39.0 || ^13.0",
        "saloonphp/laravel-plugin": "^4.3"
    },
    "require-dev": {
        "symplify/easy-coding-standard": "^13.0.0",
        "orchestra/testbench": "^10.11"
    },
    "autoload": {
        "psr-4": {
            "Uspacy\\SDK\\": "src/"
        }
    },
    "scripts": {
        "check-cs": "vendor/bin/ecs check",
        "fix-cs": "composer check-cs -- --fix"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Uspacy\\SDK\\UspacySDKServiceProvider"
            ]
        }
    }
}
